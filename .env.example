APP__NAME=QT-Agent
APP__ALIAS=千通AI助手
APP__ENV=development
APP__DEBUG=true
APP__HOST=0.0.0.0
APP__PORT=8000
APP__API_PREFIX=/api/v1
APP__LOG_LEVEL=INFO
APP__ALLOWED_ORIGINS=["*"]

DB__HOST=postgres
DB__PORT=5432
DB__NAME=qt_agent
DB__USER=qt_agent
DB__PASSWORD=qt_agent
DB__POOL_SIZE=10
DB__MAX_OVERFLOW=20
DB__ECHO=false

REDIS__HOST=redis
REDIS__PORT=6379
REDIS__DB=0
REDIS__PASSWORD=
REDIS__TTL_SECONDS=3600
REDIS__WINDOW_SIZE=20

MILVUS__HOST=milvus
MILVUS__PORT=19530
MILVUS__USER=
MILVUS__PASSWORD=
MILVUS__DATABASE=default
MILVUS__SECURE=false
MILVUS__COLLECTION=qt_agent_knowledge
MILVUS__INDEX_TYPE=AUTOINDEX
MILVUS__METRIC_TYPE=COSINE

MINIO__ENDPOINT=minio:9000
MINIO__ACCESS_KEY=minioadmin
MINIO__SECRET_KEY=minioadmin
MINIO__BUCKET=qt-agent
MINIO__SECURE=false

LLM__PROVIDER=glm
LLM__MODEL=glm-4-flash
LLM__BASE_URL=
LLM__API_KEY=
LLM__TIMEOUT_SECONDS=60

EMBEDDING__PROVIDER=default
EMBEDDING__MODEL=bge-m3
EMBEDDING__BASE_URL=
EMBEDDING__API_KEY=
EMBEDDING__DIMENSION=1024

STARTUP_RETRY__ENABLED=true
STARTUP_RETRY__MAX_ATTEMPTS=30
STARTUP_RETRY__INTERVAL_SECONDS=2
STARTUP_RETRY__TIMEOUT_SECONDS=3

CACHE__PREFIX=qt-agent
CACHE__DEFAULT_TTL_SECONDS=300
CACHE__ENABLE_LOCAL_CACHE=true

SSE__ENABLED=true
SSE__PING_INTERVAL_SECONDS=15
SSE__RETRY_MILLISECONDS=3000
